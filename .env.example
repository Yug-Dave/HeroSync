# MySQL container settings (used by db service in docker-compose)
MYSQL_ROOT_PASSWORD=herosync_root_secure
MYSQL_DATABASE=herosync
MYSQL_USER=herosync_user
MYSQL_PASSWORD=herosync_user_secure

# AI Keys — replace with your real rotated keys
GROQ_API_KEY=your_new_groq_key
GEMINI_API_KEY=your_new_gemini_key
OPENAI_API_KEY=your_new_openai_key

# Spring Boot DB connection (used by backend service)
# DB_URL=jdbc:mysql://db:3306/herosync
DB_USER=herosync_user
DB_PASSWORD=herosync_user_secure

# SPRING_PROFILES_ACTIVE=prod